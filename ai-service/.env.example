# ========================================
# Armor AI Service - Environment Variables
# ========================================

# Groq API (Primary LLM)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (Fallback LLM)
GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram API (Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI Whisper
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face / Indic ASR / Transformers
HF_API_TOKEN=your_hf_api_token_here
HF_TOPIC_MODEL=facebook/bart-large-mnli
HF_SUMMARY_MODEL=sshleifer/distilbart-cnn-12-6
HF_INDIC_ASR_MODEL=openai/whisper-large-v3

# STT provider selection: auto | openai | huggingface | groq
STT_PROVIDER=auto

# Server
PORT=8000
